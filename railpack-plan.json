{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "install": {
      "commands": ["npm ci"]
    },
    "build": {
      "inputs": [{ "step": "install" }],
      "commands": ["echo \"Skipping Next.js build for worker deployment\""]
    }
  },
  "deploy": {
    "inputs": [{ "step": "build", "include": ["."] }],
    "startCommand": "npm run worker:http"
  }
}

