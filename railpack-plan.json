{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "install": {
      "commands": [
        { "src": "package.json", "dest": "package.json" },
        { "src": "package-lock.json", "dest": "package-lock.json" },
        { "cmd": "npm ci" },
        { "src": ".", "dest": "." }
      ]
    },
    "build": {
      "inputs": [{ "step": "install" }],
      "commands": [{ "cmd": "echo Skipping Next.js build for worker service" }]
    }
  },
  "deploy": {
    "inputs": [{ "step": "build", "include": ["."] }],
    "startCommand": "npm run worker:http"
  }
}

