# =============================================================================
# Local Business SEO Audit — Environment Variables
# =============================================================================
#
# SETUP: Copy this file to ".env.local" and fill in your API keys.
#   cp .env.local.template .env.local
#
# All 4 keys marked REQUIRED are needed for real audits.
# Without them the app falls back to placeholder mock data.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED — Core Audit Pipeline (4 keys)
# -----------------------------------------------------------------------------

# Google Places API (New) — Powers GBP data, reviews, business resolution
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Enable: "Places API (New)", "Maps JavaScript API", "Geocoding API"
GOOGLE_PLACES_API_KEY=
GOOGLE_MAPS_API_KEY=

# Google PageSpeed Insights API — Website performance audit
# Get from: https://developers.google.com/speed/docs/insights/v5/get-started
GOOGLE_PSI_API_KEY=

# Serper API — Geo-grid rank tracking (245 calls/audit) + 7 citation platforms
# Get from: https://serper.dev
SERPER_API_KEY=

# Google Gemini API — AI-powered executive summary + priority actions
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_GEMINI_API_KEY=

# Gemini model to use for insight generation (Flash recommended)
# See: https://ai.google.dev/gemini-api/docs/models
# Example: gemini-2.0-flash
GEMINI_MODEL=gemini-2.0-flash

# -----------------------------------------------------------------------------
# REQUIRED — US Healthcare Citation Platforms (2 keys)
# -----------------------------------------------------------------------------

# Yelp Fusion API — Yelp listing verification
# Get from: https://www.yelp.com/developers/documentation/v3/authentication
YELP_API_KEY=

# Facebook Graph API — Meta/Facebook page verification
# Get from: https://developers.facebook.com/tools/explorer/
FACEBOOK_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# OPTIONAL — Enhanced Data (3 keys)
# -----------------------------------------------------------------------------

# Moz Link Explorer — Backlink + Domain Authority data
# Get from: https://moz.com/products/api
# Without these: website audit skips backlink score (non-blocking)
MOZ_ACCESS_ID=
MOZ_SECRET_KEY=

# Advice Local Partner API — Aggregator-level citation verification
# Get from: https://www.advicelocal.com/partner-program/
# Without these: falls back to Serper site-search on advicelocal.com
ADVICE_LOCAL_API_KEY=
ADVICE_LOCAL_PARTNER_ID=

# -----------------------------------------------------------------------------
# App Configuration
# -----------------------------------------------------------------------------

# Public base URL (used for building report links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Force mock data even if keys are set (useful for local dev/testing)
# USE_MOCK_DATA=true

# Audit pipeline hard timeout (ms). Some audits can take 3–8 minutes depending on APIs.
# Example: 600000 (10 minutes)
AUDIT_PIPELINE_TIMEOUT_MS=600000

# Debug: expose the exact JSON input sent to Gemini for summaries
# WARNING: do not enable in production
DEBUG_AI_INPUTS=false

# Debug: persist raw upstream API payloads to ./testing_data/<uuid>/
# WARNING: do not enable in production
DEBUG_PERSIST_TESTING_DATA=false
