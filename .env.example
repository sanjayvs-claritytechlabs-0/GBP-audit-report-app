# =============================================================================
# Local Business SEO Audit — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Google APIs
# -----------------------------------------------------------------------------

# GOOGLE_OAUTH_TOKEN_URI="https://oauth2.googleapis.com/token"
# #Auth Scopes
# GOOGLE_OAUTH_SCOPES = "https://www.googleapis.com/auth/calendar"
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_GBP_REDIRECT_URI="http://localhost:8000/gbp/callback"

# Google Maps API key — enables Geocoding, Places (New), and Maps JavaScript
# Get from: https://console.cloud.google.com/apis/credentials
# Enable: Maps JavaScript API, Geocoding API, Places API (New)
GOOGLE_MAPS_API_KEY=

# Google Places API key (can be the same as GOOGLE_MAPS_API_KEY)
# Enable: Places API (New) in Cloud Console
GOOGLE_PLACES_API_KEY=

# Google PageSpeed Insights API key
# Get from: https://console.cloud.google.com/apis/credentials
# Enable: PageSpeed Insights API
GOOGLE_PSI_API_KEY=

# Path to Google service account JSON file for GBP Business Information API
# The service account must have access to the Google Business Profile
# Example: /etc/secrets/gbp-service-account.json
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=

# -----------------------------------------------------------------------------
# Serper API (Rank Engine — 245 calls per audit)
# -----------------------------------------------------------------------------

# Serper.dev API key for Google Maps SERP data
# Get from: https://serper.dev/api-key
# Plans: https://serper.dev/pricing
SERPER_API_KEY=

# -----------------------------------------------------------------------------
# Google Gemini API (Insight Engine)
# -----------------------------------------------------------------------------

# Gemini API key (Google AI Studio)
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_GEMINI_API_KEY=

# Gemini model to use for insight generation (Flash recommended)
# See: https://ai.google.dev/gemini-api/docs/models
# Example: gemini-2.0-flash
GEMINI_MODEL=gemini-2.0-flash

# -----------------------------------------------------------------------------
# Moz Link Explorer (Website Auditor — Backlinks)
# -----------------------------------------------------------------------------

# Moz API access ID
# Get from: https://moz.com/products/api
MOZ_ACCESS_ID=

# Moz API secret key
MOZ_SECRET_KEY=

# -----------------------------------------------------------------------------
# Citation Checker — US Healthcare Platforms (11 platforms)
# -----------------------------------------------------------------------------

# Yelp Fusion API key (Platform 3: Yelp)
# Get from: https://www.yelp.com/developers/documentation/v3/authentication
YELP_API_KEY=

# Facebook Graph API long-lived page access token (Platform 10: Meta)
# Requires: approved Facebook Business app with Pages API access
# Get from: https://developers.facebook.com/tools/explorer/
FACEBOOK_ACCESS_TOKEN=

# Advice Local Partner API (Platform 11: Advice Local aggregator)
# Get from: https://www.advicelocal.com/partner-program/
ADVICE_LOCAL_API_KEY=
ADVICE_LOCAL_PARTNER_ID=

# Note: Platforms 2,4,5,6,7,8,9 (Healthgrades, Zocdoc, WebMD, Vitals,
# CareDash, RateMDs, Apple Maps) use Serper site-search — no extra keys needed.
# They rely on the SERPER_API_KEY configured above.

# -----------------------------------------------------------------------------
# Database — Neon PostgreSQL
# -----------------------------------------------------------------------------

# Neon database connection string (pooled, HTTP mode)
# Get from: https://neon.tech → your project → Connection Details
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=

# -----------------------------------------------------------------------------
# Redis — Upstash or Railway Redis
# -----------------------------------------------------------------------------

# Redis connection URL for BullMQ job queue + application cache
# Upstash format: rediss://default:password@host:port
# Railway format: redis://default:password@host:port
REDIS_URL=

# -----------------------------------------------------------------------------
# Cloudflare R2 (PDF Storage)
# -----------------------------------------------------------------------------

# Cloudflare account ID
# Get from: https://dash.cloudflare.com → right sidebar
R2_ACCOUNT_ID=

# R2 access key ID (create under Cloudflare → R2 → Manage R2 API Tokens)
R2_ACCESS_KEY_ID=

# R2 secret access key
R2_SECRET_ACCESS_KEY=

# R2 bucket name for storing generated PDF reports
R2_BUCKET_NAME=audit-reports

# Public R2 domain (if bucket is public, e.g., via custom domain)
# Leave empty to use pre-signed URLs instead
R2_PUBLIC_DOMAIN=

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------

# Public base URL of your deployed application
# Used for generating absolute URLs in emails and PDF links
NEXT_PUBLIC_APP_URL=http://localhost:3000

# NextAuth.js secret (random 32+ character string)
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Node environment (development | test | production)
NODE_ENV=development

# -----------------------------------------------------------------------------
# Error Tracking — Sentry
# -----------------------------------------------------------------------------

# Sentry DSN for error reporting
# Get from: https://sentry.io → Settings → Projects → [your project] → DSN
SENTRY_DSN=

# Sentry auth token for source map uploads
SENTRY_AUTH_TOKEN=

# Sentry organization slug
SENTRY_ORG=

# Sentry project name
SENTRY_PROJECT=local-business-audit

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------

# Set to "true" to use mock data for external APIs (useful for development)
USE_MOCK_DATA=false

# Maximum concurrent Serper API calls in rank engine
SERPER_CONCURRENCY=10

# Grid size for rank engine (default: 7 for 7x7 = 49 points)
RANK_GRID_SIZE=7

# Grid spacing in km (default: 0.5)
RANK_GRID_SPACING_KM=0.5

# Audit pipeline hard timeout (ms). Some audits can take 3–8 minutes depending on APIs.
# Example: 600000 (10 minutes)
AUDIT_PIPELINE_TIMEOUT_MS=600000

# Debug: expose the exact JSON input sent to Gemini for summaries
# WARNING: do not enable in production
DEBUG_AI_INPUTS=false

# Debug: persist raw upstream API payloads to ./testing_data/<uuid>/
# WARNING: do not enable in production
DEBUG_PERSIST_TESTING_DATA=false




#upstash for redis
KV_REST_API_READ_ONLY_TOKEN=
KV_REST_API_TOKEN=
KV_REST_API_URL=
KV_URL=
REDIS_URL=

QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
QSTASH_TOKEN=
QSTASH_URL=