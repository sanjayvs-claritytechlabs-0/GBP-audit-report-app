{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "install": {
      "commands": [
        "COPY:package.json package.json",
        "COPY:package-lock.json package-lock.json",
        "npm ci",
        "COPY:. ."
      ]
    },
    "build": {
      "inputs": [{ "step": "install" }],
      "commands": ["echo \"Skipping Next.js build (worker-only service)\""]
    }
  },
  "deploy": {
    "inputs": [{ "step": "build", "include": ["."] }],
    "startCommand": "npm run worker:http"
  }
}

