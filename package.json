{
  "name": "local-business-audit",
  "version": "1.0.0",
  "private": true,
  "description": "Local Business SEO Audit Report Generator — Next.js 14",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,css,md}\"",
    "test:facebook-token": "node scripts/test-facebook-token.js",
    "test:insights": "npx --yes tsx scripts/test-insights.ts",
    "test:psi": "npx --yes tsx scripts/test-psi.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:migrate": "node scripts/migrate.js",
    "worker": "ts-node --esm worker/index.ts",
    "worker:dev": "nodemon --exec ts-node --esm worker/index.ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.645.0",
    "@aws-sdk/s3-request-presigner": "^3.645.0",
    "@google/generative-ai": "^0.24.1",
    "@neondatabase/serverless": "^0.9.5",
    "@sentry/nextjs": "^8.26.0",
    "@sparticuz/chromium": "^127.0.0",
    "@tailwindcss/typography": "^0.5.14",
    "@upstash/qstash": "^2.10.1",
    "@vercel/kv": "^3.0.0",
    "axios": "^1.7.7",
    "bullmq": "^5.12.12",
    "cheerio": "^1.0.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "googleapis": "^140.0.0",
    "handlebars": "^4.7.8",
    "ioredis": "^5.4.1",
    "next": "14.2.5",
    "p-limit": "^6.1.0",
    "puppeteer": "^22.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cheerio": "^0.22.35",
    "@types/connect": "^3.4.38",
    "@types/node": "^20.16.5",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/coverage-v8": "^2.0.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.5",
    "eslint-plugin-import": "^2.29.1",
    "nodemon": "^3.1.4",
    "postcss": "^8.4.44",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.6",
    "ts-node": "^10.9.2",
    "vite-tsconfig-paths": "^5.0.1",
    "vitest": "^2.0.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
