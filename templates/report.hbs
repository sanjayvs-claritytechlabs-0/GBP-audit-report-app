<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Local SEO Audit — {{report.gbp.name}}</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
    * { margin: 0; padding: 0; box-sizing: border-box; }
    @page { size: A4; margin: 10mm 11mm; }

    body {
      font-family: 'Inter', sans-serif;
      font-size: 10.5px;
      line-height: 1.45;
      color: #4a3f5c;
      background: #faf8ff;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    /* ----- Dashboard header (matches web report strip) ----- */
    .dash-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 16px;
      padding: 14px 16px;
      margin-bottom: 10px;
      border: 1px solid #e9d5ff;
      border-radius: 10px;
      background: linear-gradient(135deg, #ede9fe 0%, #faf5ff 50%, #f5f3ff 100%);
    }
    .dash-header .eyebrow {
      font-size: 9px;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #8b7cae;
      margin-bottom: 4px;
    }
    .dash-header h1 {
      font-size: 18px;
      font-weight: 700;
      color: #5b4a78;
      line-height: 1.2;
      margin-bottom: 4px;
    }
    .dash-header .sub {
      font-size: 10px;
      color: #7c6d96;
      max-width: 320px;
    }
    .dash-header .aside {
      flex-shrink: 0;
      text-align: right;
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 6px;
    }
    .overall-ring {
      width: 64px;
      height: 64px;
      border-radius: 50%;
      border: 5px solid #ddd6fe;
      background: rgba(255,255,255,0.85);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
    }
    .overall-ring .num { font-size: 20px; font-weight: 700; color: #6b5a8e; line-height: 1; }
    .overall-ring .lbl { font-size: 7px; font-weight: 600; color: #8b7cae; text-transform: uppercase; margin-top: 2px; }
    .rating-pill {
      font-size: 10px;
      padding: 6px 10px;
      border-radius: 8px;
      border: 1px solid #e9d5ff;
      background: rgba(255,255,255,0.85);
      color: #5b4a78;
    }
    .rating-pill .star { color: #d97706; }
    .verified { font-size: 9px; color: #059669; font-weight: 600; }

    /* ----- Panels (SectionShell-style) ----- */
    .panel {
      margin-bottom: 10px;
      border: 1px solid #ede9fe;
      border-radius: 10px;
      background: #fff;
      overflow: hidden;
      break-inside: avoid;
    }
    .panel--flow {
      break-inside: auto;
    }
    .panel-hd {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 8px;
      padding: 8px 12px;
      border-bottom: 1px solid #f3e8ff;
      background: linear-gradient(90deg, #faf5ff 0%, #fff 55%, #fdf4ff 100%);
    }
    .panel-hd h2 {
      font-size: 12px;
      font-weight: 700;
      color: #5b4a78;
    }
    .panel-hd .desc {
      font-size: 9px;
      color: #8b7cae;
      margin-top: 2px;
    }
    .panel-hd-right { flex-shrink: 0; display: flex; gap: 6px; flex-wrap: wrap; justify-content: flex-end; }
    .pill-ok {
      font-size: 9px;
      font-weight: 600;
      padding: 3px 8px;
      border-radius: 999px;
      background: #ecfdf5;
      color: #065f46;
      border: 1px solid #d1fae5;
    }
    .pill-bad {
      font-size: 9px;
      font-weight: 600;
      padding: 3px 8px;
      border-radius: 999px;
      background: #fef2f2;
      color: #991b1b;
      border: 1px solid #fecaca;
    }
    .panel-bd { padding: 10px 12px 12px; }

    /* Overview row */
    .summary .k {
      font-size: 9px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: #8b7cae;
      margin-bottom: 4px;
    }
    .summary p {
      font-size: 10px;
      color: #575569;
      line-height: 1.55;
    }

    /* Category score cards */
    .score-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
    }
    .score-card {
      position: relative;
      border: 1px solid #ede9fe;
      border-radius: 8px;
      padding: 8px 8px 8px 10px;
      background: #fff;
    }
    .score-card::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      width: 3px;
      border-radius: 8px 0 0 8px;
      background: linear-gradient(180deg, #c4b5fd, #ddd6fe);
    }
    .score-card .label { font-size: 9px; color: #8b7cae; margin-bottom: 2px; }
    .score-card .num { font-size: 18px; font-weight: 700; color: #5b4a78; }
    .score-card .num span { font-size: 10px; font-weight: 400; color: #c4b5fd; }
    .score-card .bar {
      margin-top: 6px;
      height: 3px;
      border-radius: 2px;
      background: #f5f3ff;
      overflow: hidden;
    }
    .score-card .bar > span {
      display: block;
      height: 100%;
      border-radius: 2px;
      background: linear-gradient(90deg, #a78bfa, #c4b5fd);
    }

    /* Priority actions — 3-col like web */
    .actions-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
    }
    .action-card {
      border: 1px solid #ede9fe;
      border-radius: 8px;
      padding: 8px;
      background: linear-gradient(180deg, #fff 0%, #faf8ff 100%);
      break-inside: avoid;
    }
    .action-card .row {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 4px;
      margin-bottom: 6px;
    }
    .action-rank {
      width: 22px;
      height: 22px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 11px;
      background: #ddd6fe;
      color: #4a3960;
    }
    .impact-high { background: #fee2e2; color: #991b1b; padding: 2px 6px; border-radius: 999px; font-size: 8px; font-weight: 600; text-transform: uppercase; }
    .impact-medium { background: #fef3c7; color: #92400e; padding: 2px 6px; border-radius: 999px; font-size: 8px; font-weight: 600; text-transform: uppercase; }
    .impact-low { background: #d1fae5; color: #065f46; padding: 2px 6px; border-radius: 999px; font-size: 8px; font-weight: 600; text-transform: uppercase; }
    .effort-badge { background: #ede9fe; color: #5b4a78; padding: 2px 6px; border-radius: 999px; font-size: 8px; font-weight: 600; text-transform: uppercase; }
    .action-card .title { font-size: 10px; font-weight: 700; color: #5b4a78; margin-bottom: 4px; }
    .action-card .desc { font-size: 9px; color: #64748b; margin-bottom: 6px; line-height: 1.4; }
    .action-card ol { padding-left: 14px; font-size: 8.5px; color: #575569; }
    .action-card li { margin-bottom: 3px; }

    /* Tables */
    table { width: 100%; border-collapse: collapse; font-size: 9.5px; }
    th {
      text-align: left;
      padding: 5px 6px;
      background: #f5f3ff;
      color: #6b5a8e;
      font-size: 8px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      border-bottom: 1px solid #ede9fe;
    }
    td {
      padding: 5px 6px;
      border-bottom: 1px solid #f3e8ff;
      vertical-align: middle;
    }
    tr:last-child td { border-bottom: none; }
    thead { display: table-header-group; }

    .score-badge { display: inline-block; padding: 1px 8px; border-radius: 999px; font-weight: 600; font-size: 9px; }
    .score-good { background: #d1fae5; color: #065f46; }
    .score-ok { background: #fef3c7; color: #92400e; }
    .score-bad { background: #fee2e2; color: #991b1b; }

    .nap-match { color: #059669; font-weight: 700; }
    .nap-mismatch { color: #dc2626; font-weight: 700; }

    /* Website SEO cards (PDF omits Moz-style backlink metrics) */
    .web-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
    }
    .web-card {
      border: 1px solid #ede9fe;
      border-radius: 8px;
      padding: 8px;
      background: linear-gradient(180deg, #fff, #faf8ff);
      break-inside: avoid;
    }
    .web-card h3 {
      font-size: 8px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: #8b7cae;
      margin-bottom: 4px;
    }
    .web-card .big {
      font-size: 20px;
      font-weight: 700;
      color: #6b5a8e;
      line-height: 1.1;
    }
    .web-card .big.c-good { color: #059669; }
    .web-card .big.c-warn { color: #d97706; }
    .web-card .big.c-bad { color: #dc2626; }
    .web-card .row2 {
      display: flex;
      justify-content: space-between;
      font-size: 8.5px;
      color: #64748b;
      margin-top: 4px;
    }
    .web-card .row2 .v { font-weight: 600; color: #5b4a78; }
    .web-card ul { list-style: none; margin-top: 4px; }
    .web-card li {
      display: flex;
      justify-content: space-between;
      font-size: 9px;
      padding: 2px 0;
      border-bottom: 1px solid #f5f3ff;
    }
    .web-card li:last-child { border-bottom: none; }
    .ok { color: #059669; font-weight: 600; font-size: 8px; }
    .no { color: #dc2626; font-weight: 600; font-size: 8px; }

    .footer {
      text-align: center;
      font-size: 8px;
      color: #9b8ab8;
      padding: 10px 0 4px;
      margin-top: 8px;
      border-top: 1px solid #ede9fe;
    }
  </style>
</head>
<body>

  <header class="dash-header">
    <div>
      {{#if agencyLogo}}<img src="{{agencyLogo}}" alt="" style="height:22px;margin-bottom:6px;">{{/if}}
      <div class="eyebrow">Local SEO audit</div>
      <h1>{{report.gbp.name}}</h1>
      <div class="sub">{{report.gbp.address}} &middot; {{report.gbp.primaryCategory}}</div>
    </div>
    <div class="aside">
      <div class="overall-ring">
        <div class="num">{{scores.overall}}</div>
        <div class="lbl">Overall</div>
      </div>
      <div class="rating-pill">
        <span class="star">&#9733;</span> {{report.gbp.averageRating}}
        <span style="color:#8b7cae;">({{report.gbp.totalReviews}})</span>
      </div>
      {{#if report.gbp.isVerified}}<div class="verified">&#10003; Verified</div>{{/if}}
    </div>
  </header>

  <div class="panel">
    <div class="panel-hd">
      <div>
        <h2>Overview</h2>
        <div class="desc">Overall visibility score and executive summary.</div>
      </div>
    </div>
    <div class="panel-bd">
      <div class="summary">
        <div class="k">Executive summary</div>
        <p>{{report.insights.executiveSummary}}</p>
      </div>
    </div>
  </div>

  <div class="panel panel--flow">
    <div class="panel-hd">
      <div>
        <h2>Category scores</h2>
        <div class="desc">How each pillar contributes to your local presence.</div>
      </div>
    </div>
    <div class="panel-bd">
      <div class="score-grid">
        <div class="score-card">
          <div class="label">Rank score</div>
          <div class="num">{{scores.rank}}<span>/100</span></div>
          <div class="bar"><span style="width: {{scores.rank}}%;"></span></div>
        </div>
        <div class="score-card">
          <div class="label">Citations &amp; NAP</div>
          <div class="num">{{scores.citations}}<span>/100</span></div>
          <div class="bar"><span style="width: {{scores.citations}}%;"></span></div>
        </div>
        <div class="score-card">
          <div class="label">Profile completeness</div>
          <div class="num">{{scores.profileCompleteness}}<span>/100</span></div>
          <div class="bar"><span style="width: {{scores.profileCompleteness}}%;"></span></div>
        </div>
        <div class="score-card">
          <div class="label">Profile SEO</div>
          <div class="num">{{scores.profileSeo}}<span>/100</span></div>
          <div class="bar"><span style="width: {{scores.profileSeo}}%;"></span></div>
        </div>
        <div class="score-card">
          <div class="label">Reviews</div>
          <div class="num">{{scores.reviews}}<span>/100</span></div>
          <div class="bar"><span style="width: {{scores.reviews}}%;"></span></div>
        </div>
        <div class="score-card">
          <div class="label">Website SEO</div>
          <div class="num">{{scores.website}}<span>/100</span></div>
          <div class="bar"><span style="width: {{scores.website}}%;"></span></div>
        </div>
      </div>
    </div>
  </div>

  <div class="panel panel--flow">
    <div class="panel-hd">
      <div>
        <h2>Priority actions</h2>
        <div class="desc">High-impact improvements, ordered by importance.</div>
      </div>
    </div>
    <div class="panel-bd">
      <div class="actions-grid">
        {{#each report.insights.priorityActions}}
        <div class="action-card">
          <div class="row">
            <div class="action-rank">{{rank}}</div>
            <span class="impact-{{impact}}">{{impact}}</span>
            <span class="effort-badge">{{effort}}</span>
          </div>
          <div class="title">{{title}}</div>
          <div class="desc">{{description}}</div>
          <ol>
            {{#each specificSteps}}<li>{{this}}</li>{{/each}}
          </ol>
        </div>
        {{/each}}
      </div>
    </div>
  </div>

  <div class="panel panel--flow">
    <div class="panel-hd">
      <div>
        <h2>Keyword rankings</h2>
        <div class="desc">Average position and visibility across your geo-grid.</div>
      </div>
    </div>
    <div class="panel-bd">
      <table>
        <thead>
          <tr>
            <th>Keyword</th>
            <th style="text-align:center;">Avg rank</th>
            <th style="text-align:center;">#1</th>
            <th style="text-align:center;">Top 3</th>
            <th style="text-align:center;">Top 10</th>
            <th style="text-align:center;">Score</th>
          </tr>
        </thead>
        <tbody>
          {{#each report.rankings.keywordResults}}
          <tr>
            <td style="font-weight:600;color:#5b4a78;">{{keyword}}</td>
            <td style="text-align:center;"><span class="score-badge {{#if (lte avgRank 3)}}score-good{{else if (lte avgRank 10)}}score-ok{{else}}score-bad{{/if}}">{{round avgRank 1}}</span></td>
            <td style="text-align:center;">{{rank1Count}}/49</td>
            <td style="text-align:center;">{{top3Count}}/49</td>
            <td style="text-align:center;">{{top10Count}}/49</td>
            <td style="text-align:center;font-weight:700;">{{rankScore}}</td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>

  <div class="panel panel--flow">
    <div class="panel-hd">
      <div>
        <h2>Competitor benchmarking</h2>
        <div class="desc">How you stack up against nearby listings.</div>
      </div>
    </div>
    <div class="panel-bd">
      <table>
        <thead>
          <tr>
            <th>#</th>
            <th>Business</th>
            <th style="text-align:center;">Avg rank</th>
            <th style="text-align:center;">Top 3</th>
            <th style="text-align:center;">Rating</th>
            <th style="text-align:center;">Reviews</th>
          </tr>
        </thead>
        <tbody>
          {{#each report.competitors}}
          <tr>
            <td style="color:#c4b5fd;font-weight:600;">{{rank}}</td>
            <td style="font-weight:600;color:#5b4a78;">{{name}}</td>
            <td style="text-align:center;">{{avgRankAcrossGrid}}</td>
            <td style="text-align:center;">{{top3Frequency}}/49</td>
            <td style="text-align:center;">{{#if rating}}<span style="color:#d97706;">&#9733;</span> {{rating}}{{else}}&mdash;{{/if}}</td>
            <td style="text-align:center;">{{#if reviewCount}}{{formatNumber reviewCount}}{{else}}&mdash;{{/if}}</td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>

  <div class="panel panel--flow">
    <div class="panel-hd">
      <div>
        <h2>Citation &amp; listing audit</h2>
        <div class="desc">Directory presence and NAP consistency.</div>
      </div>
      <div class="panel-hd-right">
        <span class="pill-ok">{{report.citations.found}} found</span>
        <span class="pill-bad">{{report.citations.notFound}} missing</span>
      </div>
    </div>
    <div class="panel-bd">
      <table>
        <thead>
          <tr>
            <th>Platform</th>
            <th style="text-align:center;">Found</th>
            <th style="text-align:center;">Name</th>
            <th style="text-align:center;">Phone</th>
            <th style="text-align:center;">Addr</th>
            <th style="text-align:center;">Web</th>
          </tr>
        </thead>
        <tbody>
          {{#each report.citations.platforms}}
          <tr>
            <td style="font-weight:600;color:#5b4a78;">{{displayName}}</td>
            <td style="text-align:center;">{{#if found}}<span class="nap-match">&#10003;</span>{{else}}<span class="nap-mismatch">&#10007;</span>{{/if}}</td>
            <td style="text-align:center;">{{{napBadge nameMatch}}}</td>
            <td style="text-align:center;">{{{napBadge phoneMatch}}}</td>
            <td style="text-align:center;">{{{napBadge addressMatch}}}</td>
            <td style="text-align:center;">{{{napBadge websiteMatch}}}</td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>

  <div class="panel panel--flow">
    <div class="panel-hd">
      <div>
        <h2>Website SEO audit</h2>
        <div class="desc">Performance, technical health, and schema.</div>
      </div>
    </div>
    <div class="panel-bd">
      <div class="web-grid">
        <div class="web-card">
          <h3>Mobile performance</h3>
          <div class="big {{mobilePsiClass report.website.performance.mobile.score}}">{{report.website.performance.mobile.score}}</div>
          <div class="row2"><span>LCP</span><span class="v">{{round (divide report.website.performance.mobile.lcp 1000) 1}}s</span></div>
          <div class="row2"><span>CLS</span><span class="v">{{round report.website.performance.mobile.cls 2}}</span></div>
        </div>
        <div class="web-card">
          <h3>Technical health</h3>
          <ul>
            <li><span>HTTPS</span>{{#if report.website.technical.isHttps}}<span class="ok">Pass</span>{{else}}<span class="no">Fail</span>{{/if}}</li>
            <li><span>Sitemap</span>{{#if report.website.technical.hasSitemap}}<span class="ok">Pass</span>{{else}}<span class="no">Fail</span>{{/if}}</li>
            <li><span>Robots.txt</span>{{#if report.website.technical.hasRobotsTxt}}<span class="ok">Pass</span>{{else}}<span class="no">Fail</span>{{/if}}</li>
            <li><span>Mobile</span>{{#if report.website.technical.hasMobileFriendly}}<span class="ok">Pass</span>{{else}}<span class="no">Fail</span>{{/if}}</li>
          </ul>
        </div>
        <div class="web-card">
          <h3>Schema</h3>
          <ul>
            <li><span>JSON-LD</span>{{#if report.website.schema.hasSchema}}<span class="ok">Yes</span>{{else}}<span class="no">No</span>{{/if}}</li>
            <li><span>LocalBusiness</span>{{#if report.website.schema.hasLocalBusiness}}<span class="ok">Yes</span>{{else}}<span class="no">No</span>{{/if}}</li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <div class="footer">
    Local SEO Audit &middot; {{generatedAt}}
  </div>

</body>
</html>
