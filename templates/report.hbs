<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Local SEO Audit Report — {{report.gbp.name}}</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Inter', sans-serif; color: #1e293b; font-size: 12px; line-height: 1.5; }
    .page { page-break-after: always; padding: 40px; }
    .page:last-child { page-break-after: avoid; }

    /* Cover */
    .cover { background: linear-gradient(135deg, {{brandColor}} 0%, #2a5080 100%); color: white; min-height: 100vh; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; }
    .cover h1 { font-size: 36px; font-weight: 700; margin-bottom: 8px; }
    .cover .subtitle { font-size: 16px; opacity: 0.8; margin-bottom: 32px; }
    .cover .score-circle { width: 160px; height: 160px; border-radius: 50%; border: 8px solid rgba(255,255,255,0.3); display: flex; flex-direction: column; align-items: center; justify-content: center; margin: 0 auto 24px; }
    .cover .score-circle .number { font-size: 48px; font-weight: 700; }
    .cover .score-circle .label { font-size: 12px; opacity: 0.7; }
    .cover .meta { font-size: 11px; opacity: 0.6; margin-top: 32px; }

    /* Section headers */
    .section-header { font-size: 20px; font-weight: 700; color: {{brandColor}}; margin-bottom: 16px; padding-bottom: 8px; border-bottom: 2px solid {{brandColor}}; }
    .subsection { font-size: 14px; font-weight: 600; color: #334155; margin: 16px 0 8px; }

    /* Tables */
    table { width: 100%; border-collapse: collapse; margin: 12px 0; }
    th { text-align: left; padding: 8px 12px; background: #f1f5f9; color: #64748b; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }
    td { padding: 8px 12px; border-bottom: 1px solid #e2e8f0; font-size: 12px; }
    tr:last-child td { border-bottom: none; }

    /* Score badges */
    .score-badge { display: inline-block; padding: 2px 10px; border-radius: 12px; font-weight: 600; font-size: 11px; }
    .score-good { background: #d1fae5; color: #065f46; }
    .score-ok { background: #fef3c7; color: #92400e; }
    .score-bad { background: #fee2e2; color: #991b1b; }

    /* NAP badges */
    .nap-match { color: #10b981; font-weight: 700; }
    .nap-mismatch { color: #ef4444; font-weight: 700; }
    .nap-unknown { color: #94a3b8; }

    /* Cards */
    .card { border: 1px solid #e2e8f0; border-radius: 8px; padding: 16px; margin-bottom: 12px; }
    .card-header { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }

    /* Score gauge SVG */
    .gauge-container { text-align: center; margin: 16px 0; }

    /* Impact badges */
    .impact-high { background: #fee2e2; color: #991b1b; padding: 2px 8px; border-radius: 4px; font-size: 10px; font-weight: 600; }
    .impact-medium { background: #fef3c7; color: #92400e; padding: 2px 8px; border-radius: 4px; font-size: 10px; font-weight: 600; }
    .impact-low { background: #d1fae5; color: #065f46; padding: 2px 8px; border-radius: 4px; font-size: 10px; font-weight: 600; }

    .effort-badge { background: #e2e8f0; color: #475569; padding: 2px 8px; border-radius: 4px; font-size: 10px; font-weight: 600; }

    /* Grid */
    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; }

    /* CWV */
    .cwv-metric { text-align: center; padding: 12px; border: 1px solid #e2e8f0; border-radius: 8px; }
    .cwv-value { font-size: 24px; font-weight: 700; }
    .cwv-label { font-size: 10px; color: #64748b; margin-top: 4px; }
    .cwv-good { color: #10b981; }
    .cwv-needs { color: #f59e0b; }
    .cwv-poor { color: #ef4444; }

    /* Checklist */
    .check-item { display: flex; align-items: center; gap: 8px; padding: 6px 0; border-bottom: 1px solid #f1f5f9; }
    .check-pass { color: #10b981; font-weight: 700; }
    .check-fail { color: #ef4444; font-weight: 700; }

    /* Footer */
    .report-footer { text-align: center; font-size: 10px; color: #94a3b8; padding: 24px 0 0; border-top: 1px solid #e2e8f0; margin-top: 24px; }
  </style>
</head>
<body>

  <!-- Section 1: Cover Page -->
  <div class="cover page">
    {{#if agencyLogo}}<img src="{{agencyLogo}}" alt="{{agencyName}}" style="height:40px;margin-bottom:24px;">{{/if}}
    <h1>{{report.gbp.name}}</h1>
    <div class="subtitle">{{report.gbp.address}} &middot; {{report.gbp.primaryCategory}}</div>
    <div class="score-circle">
      <div class="number">{{scores.overall}}</div>
      <div class="label">Overall Score</div>
    </div>
    <div style="display:flex;gap:24px;justify-content:center;">
      <div>&#9733; {{report.gbp.averageRating}} ({{report.gbp.totalReviews}} reviews)</div>
      {{#if report.gbp.isVerified}}<div>&#10003; Verified</div>{{/if}}
    </div>
    <div class="meta">Local SEO Audit Report &middot; Generated {{generatedAt}}</div>
  </div>

  <!-- Section 2: Executive Summary -->
  <div class="page">
    <div class="section-header">Executive Summary</div>
    <p style="font-size:13px;line-height:1.7;margin-bottom:24px;">{{report.insights.executiveSummary}}</p>

    <div class="grid-3" style="margin-bottom:24px;">
      <div class="card" style="text-align:center;">
        <div style="font-size:32px;font-weight:700;color:{{scoreColor scores.rank}};">{{scores.rank}}</div>
        <div style="font-size:11px;color:#64748b;">Rank Score</div>
      </div>
      <div class="card" style="text-align:center;">
        <div style="font-size:32px;font-weight:700;color:{{scoreColor scores.citations}};">{{scores.citations}}</div>
        <div style="font-size:11px;color:#64748b;">Citations & NAP</div>
      </div>
      <div class="card" style="text-align:center;">
        <div style="font-size:32px;font-weight:700;color:{{scoreColor scores.profileCompleteness}};">{{scores.profileCompleteness}}</div>
        <div style="font-size:11px;color:#64748b;">Profile Score</div>
      </div>
    </div>
    <div class="grid-3">
      <div class="card" style="text-align:center;">
        <div style="font-size:32px;font-weight:700;color:{{scoreColor scores.profileSeo}};">{{scores.profileSeo}}</div>
        <div style="font-size:11px;color:#64748b;">Profile SEO</div>
      </div>
      <div class="card" style="text-align:center;">
        <div style="font-size:32px;font-weight:700;color:{{scoreColor scores.reviews}};">{{scores.reviews}}</div>
        <div style="font-size:11px;color:#64748b;">Reviews</div>
      </div>
      <div class="card" style="text-align:center;">
        <div style="font-size:32px;font-weight:700;color:{{scoreColor scores.website}};">{{scores.website}}</div>
        <div style="font-size:11px;color:#64748b;">Website SEO</div>
      </div>
    </div>
  </div>

  <!-- Section 3: Priority Actions -->
  <div class="page">
    <div class="section-header">Priority Actions</div>
    {{#each report.insights.priorityActions}}
    <div class="card">
      <div class="card-header">
        <div style="background:{{../../brandColor}};color:white;width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:14px;">{{rank}}</div>
        <span class="impact-{{impact}}">{{impact}} impact</span>
        <span class="effort-badge">{{effort}} effort</span>
      </div>
      <div style="font-weight:600;font-size:13px;margin-bottom:4px;">{{title}}</div>
      <div style="color:#64748b;font-size:11px;margin-bottom:8px;">{{description}}</div>
      <ol style="padding-left:20px;font-size:11px;color:#475569;">
        {{#each specificSteps}}<li style="margin-bottom:4px;">{{this}}</li>{{/each}}
      </ol>
    </div>
    {{/each}}
  </div>

  <!-- Section 4: Keyword Rankings -->
  <div class="page">
    <div class="section-header">Keyword Rankings</div>
    <table>
      <thead>
        <tr>
          <th>Keyword</th>
          <th style="text-align:center;">Avg Rank</th>
          <th style="text-align:center;">#1 Spots</th>
          <th style="text-align:center;">Top 3</th>
          <th style="text-align:center;">Top 10</th>
          <th style="text-align:center;">Score</th>
        </tr>
      </thead>
      <tbody>
        {{#each report.rankings.keywordResults}}
        <tr>
          <td style="font-weight:500;">{{keyword}}</td>
          <td style="text-align:center;"><span class="score-badge {{#if (lte avgRank 3)}}score-good{{else if (lte avgRank 10)}}score-ok{{else}}score-bad{{/if}}">{{round avgRank 1}}</span></td>
          <td style="text-align:center;">{{rank1Count}}/49</td>
          <td style="text-align:center;">{{top3Count}}/49</td>
          <td style="text-align:center;">{{top10Count}}/49</td>
          <td style="text-align:center;font-weight:600;">{{rankScore}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>

  <!-- Section 7: Competitors -->
  <div class="page">
    <div class="section-header">Competitor Benchmarking</div>
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Business</th>
          <th style="text-align:center;">Avg Rank</th>
          <th style="text-align:center;">Top 3</th>
          <th style="text-align:center;">Rating</th>
          <th style="text-align:center;">Reviews</th>
        </tr>
      </thead>
      <tbody>
        {{#each report.competitors}}
        <tr>
          <td>{{rank}}</td>
          <td style="font-weight:500;">{{name}}</td>
          <td style="text-align:center;">{{avgRankAcrossGrid}}</td>
          <td style="text-align:center;">{{top3Frequency}}/49</td>
          <td style="text-align:center;">{{#if rating}}&#9733; {{rating}}{{else}}&mdash;{{/if}}</td>
          <td style="text-align:center;">{{#if reviewCount}}{{formatNumber reviewCount}}{{else}}&mdash;{{/if}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>

  <!-- Section 10: Citation Audit -->
  <div class="page">
    <div class="section-header">Citation & Listing Audit</div>
    <div class="grid-2" style="margin-bottom:16px;">
      <div class="card" style="text-align:center;">
        <div style="font-size:28px;font-weight:700;color:#10b981;">{{report.citations.found}}</div>
        <div style="font-size:11px;color:#64748b;">Platforms Found</div>
      </div>
      <div class="card" style="text-align:center;">
        <div style="font-size:28px;font-weight:700;color:#ef4444;">{{report.citations.notFound}}</div>
        <div style="font-size:11px;color:#64748b;">Platforms Missing</div>
      </div>
    </div>
    <table>
      <thead>
        <tr>
          <th>Platform</th>
          <th style="text-align:center;">Found</th>
          <th style="text-align:center;">Name</th>
          <th style="text-align:center;">Phone</th>
          <th style="text-align:center;">Address</th>
          <th style="text-align:center;">Website</th>
        </tr>
      </thead>
      <tbody>
        {{#each report.citations.platforms}}
        <tr>
          <td style="font-weight:500;">{{displayName}}</td>
          <td style="text-align:center;">{{#if found}}<span class="nap-match">&#10003;</span>{{else}}<span class="nap-mismatch">&#10007;</span>{{/if}}</td>
          <td style="text-align:center;">{{{napBadge nameMatch}}}</td>
          <td style="text-align:center;">{{{napBadge phoneMatch}}}</td>
          <td style="text-align:center;">{{{napBadge addressMatch}}}</td>
          <td style="text-align:center;">{{{napBadge websiteMatch}}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>

  <!-- Section 11-15: Website Audit -->
  <div class="page">
    <div class="section-header">Website SEO Audit</div>

    <div class="subsection">Core Web Vitals (Mobile)</div>
    <div class="grid-3" style="margin-bottom:16px;">
      <div class="cwv-metric">
        <div class="cwv-value {{#if (lte report.website.performance.mobile.lcp 2500)}}cwv-good{{else if (lte report.website.performance.mobile.lcp 4000)}}cwv-needs{{else}}cwv-poor{{/if}}">
          {{round (divide report.website.performance.mobile.lcp 1000) 1}}s
        </div>
        <div class="cwv-label">LCP</div>
      </div>
      <div class="cwv-metric">
        <div class="cwv-value {{#if (lte report.website.performance.mobile.cls 0.1)}}cwv-good{{else if (lte report.website.performance.mobile.cls 0.25)}}cwv-needs{{else}}cwv-poor{{/if}}">
          {{round report.website.performance.mobile.cls 2}}
        </div>
        <div class="cwv-label">CLS</div>
      </div>
      <div class="cwv-metric">
        <div class="cwv-value">{{report.website.performance.mobile.score}}</div>
        <div class="cwv-label">PSI Score</div>
      </div>
    </div>

    <div class="subsection">Technical Health</div>
    <div class="check-item"><span class="{{#if report.website.technical.isHttps}}check-pass{{else}}check-fail{{/if}}">{{#if report.website.technical.isHttps}}&#10003;{{else}}&#10007;{{/if}}</span> HTTPS</div>
    <div class="check-item"><span class="{{#if report.website.technical.hasSitemap}}check-pass{{else}}check-fail{{/if}}">{{#if report.website.technical.hasSitemap}}&#10003;{{else}}&#10007;{{/if}}</span> XML Sitemap</div>
    <div class="check-item"><span class="{{#if report.website.technical.hasRobotsTxt}}check-pass{{else}}check-fail{{/if}}">{{#if report.website.technical.hasRobotsTxt}}&#10003;{{else}}&#10007;{{/if}}</span> Robots.txt</div>
    <div class="check-item"><span class="{{#if report.website.technical.hasMobileFriendly}}check-pass{{else}}check-fail{{/if}}">{{#if report.website.technical.hasMobileFriendly}}&#10003;{{else}}&#10007;{{/if}}</span> Mobile Friendly</div>
    <div class="check-item"><span class="{{#if report.website.schema.hasLocalBusiness}}check-pass{{else}}check-fail{{/if}}">{{#if report.website.schema.hasLocalBusiness}}&#10003;{{else}}&#10007;{{/if}}</span> LocalBusiness Schema</div>

    <div class="subsection">Backlink Authority</div>
    <div class="grid-3">
      <div class="card" style="text-align:center;">
        <div style="font-size:28px;font-weight:700;color:{{../../brandColor}};">{{report.website.backlinks.domainAuthority}}</div>
        <div style="font-size:11px;color:#64748b;">Domain Authority</div>
      </div>
      <div class="card" style="text-align:center;">
        <div style="font-size:28px;font-weight:700;">{{report.website.backlinks.linkingDomains}}</div>
        <div style="font-size:11px;color:#64748b;">Linking Domains</div>
      </div>
      <div class="card" style="text-align:center;">
        <div style="font-size:28px;font-weight:700;color:{{#if (lte report.website.backlinks.spamScore 5)}}#10b981{{else}}#ef4444{{/if}};">{{report.website.backlinks.spamScore}}%</div>
        <div style="font-size:11px;color:#64748b;">Spam Score</div>
      </div>
    </div>
  </div>

  <div class="report-footer">
    <p>Generated by LocalSEO Audit &middot; {{generatedAt}} &middot; Powered by Gemini</p>
  </div>

</body>
</html>
